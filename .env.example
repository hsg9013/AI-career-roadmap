# ============================================================================
# AI Career Roadmap — 환경 변수 템플릿 (.env로 복사 후 값 채우기)
# 프로젝트 네트워크 표준: 운영 도메인 p16.sumzip.com, 웹 9516, API 9536
# ============================================================================

# --- 공통 ---
NODE_ENV=development
TZ=Asia/Seoul

# --- 백엔드 (포트 9536, 변경 금지) ---
PORT=9536
JWT_ACCESS_SECRET=replace-me-min-32-bytes-random-string
JWT_REFRESH_SECRET=replace-me-min-32-bytes-different-random
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# CORS allowlist (운영 도메인 + 로컬)
CORS_ORIGINS=http://localhost:9516,https://p16.sumzip.com

# --- DB (로컬은 Docker, 운영은 mis.iptime.org:13306) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pioneer16
DB_PASSWORD=pioneer26
DB_NAME=pioneer16
DB_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- MinIO (S3 호환) ---
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PORTFOLIOS=portfolios
S3_BUCKET_SUBMISSIONS=mission-submissions
S3_BUCKET_DATA_EXPORTS=data-exports
S3_BUCKET_INVOICES=invoices

# --- 외부 LLM (R-1) ---
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5
# 003 US1: 호출 가드(타임아웃·응답 토큰 상한). 미설정 시 8000ms / 1024.
LLM_TIMEOUT_MS=8000
LLM_MAX_TOKENS=1024
# 003 US1: 일일 토큰 예산(비용 가드). 0=무제한(개발). 초과 시 규칙 폴백(fallback_reason=budget).
AI_DAILY_TOKEN_BUDGET=0

# --- 004 광고·제휴 토글 (기본 off, 'true'/'1' 로 활성) ---
ADS_ENABLED=false
AFFILIATE_ENABLED=false

# --- 005 결제 Sandbox/가상 시나리오 토글 (데모 기본 on, 'false'/'0' 로 비활성) ---
PAYMENT_SANDBOX_ENABLED=true

# --- PortOne 결제 (R-3) ---
PORTONE_IMP_KEY=
PORTONE_IMP_SECRET=

# --- PortOne Payouts (R-8 멘토 정산) ---
PORTONE_PAYOUTS_API_KEY=
PORTONE_PAYOUTS_API_SECRET=
PAYOUT_MONTHLY_CRON="0 2 1 * *"
PAYOUT_WITHHOLDING_BPS=330

# --- 메일러 (R-4) ---
MAILER_PROVIDER=naver-cloud
MAILER_API_KEY=
MAILER_FROM=no-reply@p16.sumzip.com

# --- 모바일 푸시 (R-6) ---
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.sumzip.p16
APNS_KEY_P8_PATH=./secrets/AuthKey_XXXXXX.p8

# --- OAuth (US6 소셜 로그인) ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=

# 003 US6: 학교 이메일 확인 링크·소셜 콜백 기준 웹 URL.
WEB_BASE_URL=https://p16.sumzip.com

# --- 003 US5: 외부 수집 피드 (공식 오픈API·제휴 피드만, 크롤링 금지) ---
# 미설정 시 dev 샘플 수집. 설정 시 해당 JSON 피드를 일 단위로 fetch.
FEED_JOBPOSTING_URL=
FEED_CERTIFICATION_URL=
FEED_CONTEST_URL=
FEED_STALE_AFTER_DAYS=14
FEED_COLLECT_INTERVAL_MS=86400000

# --- 프런트 웹 (포트 9516, 변경 금지) ---
VITE_PORT=9516
VITE_API_BASE_URL=http://localhost:9536/v1
# 003 US6: 설정 시 네이버 실 OAuth 리다이렉트, 미설정 시 dev 합성 로그인.
VITE_NAVER_CLIENT_ID=

# --- 운영 빌드 전용 (참고) ---
# VITE_API_BASE_URL=https://p16.sumzip.com/api/v1
